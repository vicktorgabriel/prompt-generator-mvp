{
  "name": "prompt-generator-mvp",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "description": "MVP de generador inteligente de prompts con motor semántico determinístico, interfaz web y CLI.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch apps/web-chat/src/server.ts",
    "start": "tsx apps/web-chat/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "cli": "node src/cli/index.js",
    "test": "node --test tests/*.test.js"
  },
  "bin": {
    "prompt-gen": "src/cli/index.js"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
